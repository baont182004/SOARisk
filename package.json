{
  "name": "soc-soar-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@soc-soar/shared --filter=@soc-soar/web --parallel",
    "dev:api": "turbo run dev --filter=@soc-soar/shared --filter=@soc-soar/api --parallel",
    "dev:worker": "turbo run dev --filter=@soc-soar/shared --filter=@soc-soar/worker --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "smoke:test": "node scripts/smoke-test.mjs",
    "clean": "rimraf --glob .turbo \"apps/*/.turbo\" \"apps/*/dist\" \"apps/web/.next\" \"packages/*/.turbo\" \"packages/*/dist\" \"**/*.tsbuildinfo\""
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.2",
    "pnpm": "10.11.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
